# Bu faylni .env nomiga ko'chiring va haqiqiy qiymatlarni kiriting.
# .env faylini hech qachon git'ga yoki boshqalarga yubormang — u maxfiy login ma'lumotini saqlaydi.

# Asosiy autentifikatsiya usuli (to'liq avtomatik sync.py uchun) — UCM admin
# panelga kiradigan login/parol. Skript o'zi challenge-response (MD5) login
# qilib, sessiyani avtomatik oladi va yangilaydi. Parol tarmoqqa hech qachon
# ochiq yuborilmaydi.
GRANDSTREAM_USER=""
GRANDSTREAM_PASSWORD=""

# Ba'zi tarmoqlarda /cgi yo'liga proksi darajasida "Authorization: Basic ..."
# ham talab qilinishi mumkin — DevTools > Network > istalgan cgi so'rovi >
# Headers > Request Headers'dan "Basic " so'zidan keyingi qismini qo'ying.
# GRANDSTREAM_BASIC=""

# Ixtiyoriy/zaxira — Brauzer DevTools > Network > biror so'rovni tanlang >
# Headers > Request Headers > "Cookie" qatorini TO'LIQ shu yerga ko'chiring.
# GRANDSTREAM_COOKIE=""

# Quyidagilar ixtiyoriy — agar kerak bo'lmasa shunday qoldiring (default qiymatlar ishlatiladi).
# GRANDSTREAM_BASE=https://grandstream.realsoft.uz/cgi
# OUTPUT_DIR=recordings
# FILES_LIST=files.txt
# PAUSE_SECONDS=0.15
